      "id": "scenario_01",
      "title": "At the Shop",
      "goal": "Choose the correct case while speaking in context.",
      "lessons": [
        {
          "id": "L01",
          "title": "Where are you? (Locative)",
          "description": "Use nominative vs. locative in real sentence production.",
          "xp": 15,
          "focusCase": "locative",
          "vocabulary": [
            {
              "id": "v_shop",
              "lithuanian": "parduotuvė",
              "english": "shop",
              "scenarioSentence": "Aš esu parduotuvėje.",
              "scenarioSentenceEN": "I am in the shop.",
              "srsProductionPrompt": "Say: I am in the shop.",
              "caseInSentence": "locative",
              "caseNote": "After 'esu', use locative for place: parduotuvė → parduotuvėje.",
              "productionForms": {
                "nominative": "parduotuvė",
                "locative": "parduotuvėje"
              }
            }
          ],
          "exercises": [
            {
              "type": "case-transform",
              "instruction": "Put the word in the correct form: Aš esu ___",
              "baseForm": "parduotuvė",
              "answer": "parduotuvėje",
              "caseNote": "Location with 'esu' needs locative."
            },
            {
              "type": "scenario-dialogue",
              "instruction": "Complete your turn in Lithuanian.",
              "dialogue": [
                { "speaker": "Rūta", "lt": "Kur tu esi?", "en": "Where are you?" },
                { "speaker": "You", "prompt": "Say: I am in the shop", "template": "Aš esu ___." }
              ],
              "answer": "Aš esu parduotuvėje",
              "caseNote": "The place answer needs locative ending -ėje."
            }
          ]
        }
      ]
    }
